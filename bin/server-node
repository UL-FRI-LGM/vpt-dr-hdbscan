#!/usr/bin/env node

// server.js
import { spawn } from 'node:child_process';
// import { http } from 'http';
import http from 'node:http';
import fs, { read } from 'node:fs';
import path from 'node:path';
// const http = require('http');
// const fs = require('fs');
// const path = require('path');

const basedir = 'build';
const port = process.env.PORT || 3000;

export function runPython(bytes) {
    fs.writeFile('./bin/data.raw', bytes, err => {
        if (err) {
            console.error(err);
        }
        else {
            console.log("file written succesfully");
        }
    });
  return new Promise((resolve, reject) => {
    const p = spawn('python.exe', ['./bin/processing.py'], {
        stdio: ['pipe', 'pipe', 'pipe']
    });
    const chunks = [];
    p.stdout.on('data', d => chunks.push(d));
    p.stderr.on('data', e => console.error(e.toString()));

    p.on('close', code => {
      if (code !== 0) reject(code);
      else resolve(Buffer.concat(chunks));
    });
  });
}

http.createServer(function(request, response) {
    const range = request.headers.range;
    if (range) {
        console.log(request.method, request.url, range);
    } else {
        console.log(request.method, request.url);
    }

    let filePath = request.url;
    if (request.url === '/') {
        filePath = '/index.html';
    }

    const extname = String(path.extname(filePath)).toLowerCase();
    let contentType = 'text/html';
    const mimeTypes = {
        '.html': 'text/html',
        '.js': 'text/javascript',
        '.css': 'text/css',
        '.json': 'application/json',
        '.png': 'image/png',
        '.jpg': 'image/jpg',
        '.gif': 'image/gif',
        '.svg': 'image/svg+xml',
        '.wav': 'audio/wav',
        '.mp4': 'video/mp4',
        '.woff': 'application/font-woff',
        '.ttf': 'application/font-ttf',
        '.otf': 'application/font-otf'
    };

    contentType = mimeTypes[extname] || 'application/octet-stream';

    if (request.method === 'GET' && request.url !== '/output' && request.url !== '/bumps') {
        fs.readFile(basedir + filePath, function(error, content) {
            if (error) {
                if (error.code == 'ENOENT') {
                    console.log('404: ' + filePath);
                    response.writeHead(404);
                    response.end();
                } else {
                    console.log('500: ' + filePath);
                    response.writeHead(500);
                    response.end('Server error: ' + error.code);
                }
            } else {
                if (range) {
                    const re = /^bytes=([0-9]+)-([0-9]+)$/;
                    const match = range.match(re);
                    if (match) {
                        const rangeStart = parseInt(match[1], 10);
                        const rangeEnd = parseInt(match[2], 10);
                        content = content.slice(rangeStart, rangeEnd + 1);
                    }
                }
                response.writeHead(200, {
                    'Content-Type'   : contentType,
                    'Content-Length' : content.length,
                    'Access-Control-Allow-Origin': '*',
                    'Access-Control-Allow-Methods': 'GET',
                    'Access-Control-Allow-Headers': 'Range'
                });
                response.end(content, 'utf-8');
            }
        });
    } else if (request.method === 'HEAD' || request.method === 'OPTIONS') {
        fs.lstat(basedir + filePath, function(error, stat) {
            if (error) {
                if (error.code == 'ENOENT') {
                    console.log('404: ' + filePath);
                    response.writeHead(404);
                    response.end();
                } else {
                    console.log('500: ' + filePath);
                    response.writeHead(500);
                    response.end('Server error: ' + error.code);
                }
            } else {
                response.writeHead(200, {
                    'Content-Type'   : contentType,
                    'Content-Length' : stat.size,
                    'Access-Control-Allow-Origin': '*',
                    'Access-Control-Allow-Methods': 'GET',
                    'Access-Control-Allow-Headers': 'Range'
                });
                response.end();
            }
        });
    } else if (request.method === 'POST' && request.url === '/process') {
        console.log('POST /process hit');

        const chunks = [];

        request.on('data', chunk => {
            chunks.push(chunk); // Buffer chunks
        });

        request.on('end', async () => {
            try {
                const inputBytes = Buffer.concat(chunks);

                console.log('Received bytes:', inputBytes.length);

                const outputBytes = await runPython(inputBytes);

                response.writeHead(200, {
                    'Content-Type': 'application/octet-stream'
                });
                response.end(outputBytes);

            } catch (err) {
                console.error(err);
                response.writeHead(500);
                response.end('Python failed');
            }
        });
    } else if (request.method === 'GET' && request.url === '/output') {
        const bin_file = './bin/output.bin';
        // console.log("Looking for:", require('path').resolve('./output.bin'));
        fs.readFile(bin_file, function(error, content) {
            console.log(error);
            if (error) {
                if (error.code == 'ENOENT') {
                    console.log('404: ' + bin_file);
                    response.writeHead(404);
                    response.end();
                } else {
                    console.log('500: ' + bin_file);
                    response.writeHead(500);
                    response.end('Server error: ' + error.code);
                }
            } else {
                response.writeHead(200, {
                    'Content-Type'   : contentType,
                    'Content-Length' : content.length,
                    'Access-Control-Allow-Origin': '*',
                    'Access-Control-Allow-Methods': 'GET',
                });
                response.end(content);
            }
        });
    } else if (request.method === 'GET' && request.url === '/bumps') {
        const bin_file = './bin/bumps.json';
        // console.log("Looking for:", require('path').resolve('./output.bin'));
        fs.readFile(bin_file, function(error, content) {
            console.log(error);
            if (error) {
                if (error.code == 'ENOENT') {
                    console.log('404: ' + bin_file);
                    response.writeHead(404);
                    response.end();
                } else {
                    console.log('500: ' + bin_file);
                    response.writeHead(500);
                    response.end('Server error: ' + error.code);
                }
            } else {
                response.writeHead(200, {
                    'Content-Type'   : contentType,
                    'Content-Length' : content.length,
                    'Access-Control-Allow-Origin': '*',
                    'Access-Control-Allow-Methods': 'GET',
                });
                response.end(content);
            }
        });
    }
    else {
        response.writeHead(404);
        response.end();
    }

}).listen(port);

console.log('Listening on port ' + port);
